---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Traditional African Earth Tones - Ghana Cocoa Inspired */
    --aw-color-primary: rgb(46, 35, 26);      /* Deep rich cocoa brown */
    --aw-color-secondary: rgb(89, 67, 40);    /* Medium earth brown */
    --aw-color-accent: rgb(235, 107, 59);     /* Terracotta orange - vibrant and accessible */

    /* Light mode backgrounds */
    --aw-color-text-heading: rgb(28, 18, 12);   /* Dark brown for headings */
    --aw-color-text-default: rgb(46, 35, 26);    /* Dark brown text */
    --aw-color-text-muted: rgb(98, 70, 45, 0.88); /* Warm muted - WCAG AA compliant */
    --aw-color-bg-page: rgb(245, 230, 215);     /* Light warm beige background */

    --aw-color-bg-page-dark: rgb(55, 39, 26);   /* Dark brown for dark sections */

    ::selection {
      background-color: #e67e22;
      color: #ffffff;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Dark mode - still using African earth tones */
    --aw-color-primary: rgb(55, 39, 26);        /* Deep cocoa brown */
    --aw-color-secondary: rgb(89, 67, 40);      /* Medium earth brown */
    --aw-color-accent: rgb(235, 107, 59);       /* Terracotta orange - vibrant */

    --aw-color-text-heading: rgb(240, 230, 220); /* Warm off-white */
    --aw-color-text-default: rgb(235, 220, 210); /* Off-white text */
    --aw-color-text-muted: rgb(187, 160, 145, 0.90); /* Muted warm gray - WCAG AA compliant */
    --aw-color-bg-page: rgb(35, 26, 18);         /* Very dark brown (almost black) */

    ::selection {
      background-color: #cd853f;
      color: #fefbd8;
    }
  }
</style>
