---
// Custom Icon component that uses native SVG with tabler icon paths
interface Props {
  name: string;
  class?: string;
}

const { name, class: className } = Astro.props;
// Map common icon names to their SVG paths
const iconPaths: Record<string, string> = {
  'tabler-star': '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  'tabler-check': '<polyline points="20 6 9 17 4 12"/>',
  'tabler-x': '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
  // Brand icons for social share
  'tabler:brand-x': '<circle cx="12" cy="12" r="10"/><path d="M4.93 4.93l14.14 14.14"/><path d="M14.83 9.17l5.66 5.66"/></svg>',
  'tabler:brand-facebook': '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/><rect x="2" y="9" width="4" height="12"/></svg>',
  'tabler:brand-linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/></svg>',
  'tabler-plus': '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
  'tabler-minus': '<line x1="5" y1="12" x2="19" y2="12"/>',
  'tabler-chevron-left': '<polyline points="15 18 9 12 15 6"/>',
  'tabler-chevron-right': '<polyline points="9 18 15 12 9 6"/>',
  'tabler-chevron-up': '<polyline points="18 15 12 9 6 15"/>',
  'tabler-chevron-down': '<polyline points="6 9 12 15 18 9"/>',
  'tabler-info': '<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>',
  'tabler-linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/>',
  'tabler-sun': '<circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>',
  'tabler-moon': '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>',
};
---

{iconPaths[name] ? (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.5">
    {new Function(`return \`${iconPaths[name]}\``)()} as unknown as Element
  </svg>
) : (
  // Fallback to star icon if no path found
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.5">
    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
  </svg>
)}
