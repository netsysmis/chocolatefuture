---
import { SEO } from 'astro-seo';

import type { SEOProps } from 'astro-seo';

const METADATA = {
  title: {
    default: 'The Chocolate Future',
    template: '%s — The Chocolate Future',
  },
  description: "The Chocolate Future connects diaspora capital to Ghana's cocoa-processing industry, creating jobs and strengthening local value chains.",
  robots: { index: true, follow: true },
};
const I18N = {
  language: 'en',
};

export interface Props {
  title?: string;
  dontUseTitleTemplate?: boolean;
}

const {
  title = METADATA?.title?.default,
  ignoreTitleTemplate = false,
} = Astro.props;

function buildOpenGraph(): SEOProps['openGraph'] | undefined {
  return {
    basic: {
      title: title || METADATA?.title?.default || '',
      type: 'website',
    },
  };
}

const seoProps: SEOProps = {
  title: title,
  titleTemplate: ignoreTitleTemplate ? '%s' : METADATA?.title?.template || '%s',
  description: METADATA?.description,
  openGraph: buildOpenGraph(),
  robots: METADATA?.robots,
};
---

<SEO {...seoProps} />
