---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Stats from '~/components/widgets/Stats.astro';

const metadata = {
  title: 'The Chocolate Future — Ghana\'s Cocoa Value Chain Initiative',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    tagline="Ghana's Cocoa Future"
    image={{
      src: '/hero.jpg',
      alt: 'Ghana cocoa farmers and traditional processing',
    }}
  >
    <div class="font-bold font-heading leading-tighter tracking-tighter mb-4 dark:text-gray-200 md:text-3xl text-2xl">
      Empowering Ghana's Cocoa Farmers Through<br />
      <span class="text-accent dark:text-white">Local Processing & Diaspora Investment</span>
    </div>

    <Fragment slot="subtitle">
      Ghana and Cote d'Ivoire produce over 60% of the world's cocoa, yet capture only 2-4% of the value.
      The Chocolate Future bridges this gap by connecting diaspora capital to Ghana's local processing agenda,
      creating jobs, strengthening industrial capacity, and building a more resilient cocoa economy.
    </Fragment>
  </Hero>

  <!-- Key Statistics -->
  <Stats
    title="Our Impact at a Glance"
    stats={[
      { title: 'Global Cocoa Share', amount: '60%+' },
      { title: 'Value Captured by Africa', amount: '~3%' },
      { title: 'Target: Local Processing', amount: '50%' },
      { title: 'Countries Supported', amount: '2' },
    ]}
  />

  <!-- The Problem Section -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="problem">
    <div class="max-w-6xl mx-auto" data-aw-section>
      <h2 class="text-4xl font-bold text-center mb-8 text-white">The Structural Gap</h2>
      <p class="text-xl text-gray-200 dark:text-gray-300 text-center max-w-4xl mx-auto leading-relaxed">
        Cocoa-producing countries export raw beans while the most profitable parts of the value chain—
        grinding, refining, manufacturing, branding, and retail—are concentrated elsewhere.
        Any long-term solution must move beyond production alone toward local processing and value-added manufacturing.
      </p>
    </div>
  </section>

  <!-- Ghana's Response -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="response">
    <div class="max-w-6xl mx-auto" data-aw-section>
      <h2 class="text-3xl font-bold mb-8 text-white">Ghana's Policy Response</h2>
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="space-y-6">
          <p class="text-lg text-gray-200 dark:text-gray-300 leading-relaxed">
            Beginning with the 2026/27 crop season, Ghana has directed that at least <strong>50% of cocoa beans be processed locally</strong>.
            These reforms increase domestic value addition, support local processors, revive industrial capacity, and reduce dependence on external financing.
          </p>
          <p class="text-lg text-gray-200 dark:text-gray-300 leading-relaxed">
            This policy creates a timely opening for investment into processing infrastructure, working capital, and market development that can transform Ghana from a raw-bean exporter into a stronger participant in higher-value segments of the cocoa economy.
          </p>
        </div>
        <img src="/processing.jpg"
             alt="Ghana cocoa processing facility"
             class="rounded-lg shadow-2xl w-full h-auto"/>
      </div>
    </div>
  </section>

  <!-- Diaspora as the 17th Region -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="diaspora">
    <div class="max-w-6xl mx-auto text-center" data-aw-section>
      <h2 class="text-3xl font-bold mb-8 text-white">The Diaspora as the 17th Region</h2>
      <p class="text-xl text-gray-200 dark:text-gray-300 max-w-4xl mx-auto leading-relaxed mb-12">
        Ghana's "17th Region" concept mobilizes diaspora participation in national development. Treated as a formal partner—not just a symbolic audience—the global African diaspora brings capital, expertise, and innovation to sectors like cocoa where it can bridge the gap between national ambition and industrial expansion.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547]">
          <h3 class="text-xl font-bold mb-4 text-orange-300">Capital</h3>
          <p class="text-gray-200 dark:text-gray-300">Diaspora investment in Ghana's cocoa-processing industry as a strategic vehicle for national development.</p>
        </div>
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547]">
          <h3 class="text-xl font-bold mb-4 text-orange-300">Expertise</h3>
          <p class="text-gray-200 dark:text-gray-300">Skills transfer and technical knowledge to strengthen Ghana's industrial capacity in cocoa manufacturing.</p>
        </div>
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547]">
          <h3 class="text-xl font-bold mb-4 text-orange-300">Innovation</h3>
          <p class="text-gray-200 dark:text-gray-300">Business networks and market access to create sustainable value chains anchored in Ghana.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="impact">
    <div class="max-w-6xl mx-auto" data-aw-section>
      <h2 class="text-3xl font-bold mb-8 text-center text-white">Our Impact Areas</h2>

      <Features2
        title="Building a Sustainable Cocoa Future"
        subtitle="Connecting diaspora capital to Ghana's policy objective of local processing so that more of the cocoa value chain is retained within the country."
        items={[
          {
            title: 'Processing Infrastructure',
            description: 'Investment in facilities for grinding, refining, and manufacturing higher-value cocoa products within Ghana.',
            icon: 'tabler-buildings',
          },
          {
            title: 'Local Employment',
            description: 'Creating jobs for Ghanaian workers in processing plants and related industries across cocoa regions.',
            icon: 'tabler-briefcase',
          },
          {
            title: 'Skills Development',
            description: 'Training programs transferring technical expertise from diaspora partners to local workforce.',
            icon: 'tabler-student',
          },
          {
            title: 'Market Development',
            description: 'Building local brands that compete globally while keeping profits within Ghana and Cote d\'Ivoire.',
            icon: 'tabler-arrow-up-right',
          },
          {
            title: 'Financial Inclusion',
            description: 'Providing working capital to small processors who have been excluded from traditional financing.',
            icon: 'tabler-wallet',
          },
          {
            title: 'Community Investment',
            description: 'Supporting rural development in cocoa-growing communities beyond factory gates.',
            icon: 'tabler-heart',
          },
        ]}
      />
    </div>
  </section>

  <!-- Our Mission Statement -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="mission">
    <div class="max-w-4xl mx-auto text-center" data-aw-section>
      <h2 class="text-3xl font-bold mb-8 text-white">Our Mission</h2>
      <p class="text-xl text-gray-200 dark:text-gray-300 leading-relaxed italic">
        "The Chocolate Future offers a credible platform for investment that is economically strategic, socially meaningful, and nationally aligned—with Ghana as our home."
      </p>
      <p class="text-lg text-gray-300 dark:text-gray-400 mt-6">
        Registered in both Delaware (USA) and Ghana, we serve as the vehicle through which members of the 17th Region and aligned partners can invest in Ghana's cocoa-processing industry.
      </p>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="values">
    <div class="max-w-6xl mx-auto" data-aw-section>
      <h2 class="text-3xl font-bold mb-8 text-center text-white">Our Values</h2>

      <Steps2
        title="Guiding Principles"
        subtitle="Our approach to ethical cocoa value chain development in Ghana and across West Africa."
        items={[
          {
            title: 'Local Partnership First',
            description: 'We build on Ghana\'s national agenda, not parallel initiatives. Our investments align with government policy and local needs.',
          },
          {
            title: 'Economic Transformation',
            description: 'Commercial returns are inextricably linked to national transformation. Profit and impact advance together.',
          },
          {
            title: 'Diaspora Integration',
            description: 'We treat the diaspora as active partners, not distant donors. Investment, innovation, and skills transfer are our focus.',
          },
          {
            title: 'Sustainable Development',
            description: 'Our model advances commercial viability while supporting community wellbeing and environmental stewardship in cocoa regions.',
          },
        ]}
      />
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 px-6 bg-[#5D4037] dark:bg-[#3E2723]" id="join">
    <div class="max-w-4xl mx-auto text-center" data-aw-section>
      <h2 class="text-4xl font-bold mb-8 text-white">Join the 17th Region</h2>
      <p class="text-xl text-gray-200 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed mb-10">
        Connect your capital, expertise, and networks to Ghana's cocoa future. Together we transform raw bean exports into sustainable prosperity for millions of farmers and their communities.
      </p>

      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547] text-center">
          <h3 class="text-2xl font-bold text-orange-300 mb-3">$10K+</h3>
          <p class="text-gray-200 dark:text-gray-300">Minimum Investment</p>
        </div>
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547] text-center">
          <h3 class="text-2xl font-bold text-orange-300 mb-3">USA</h3>
          <p class="text-gray-200 dark:text-gray-300">Based in Delaware</p>
        </div>
        <div class="bg-[#4E342E] p-8 rounded-lg border border-[#795547] text-center">
          <h3 class="text-2xl font-bold text-orange-300 mb-3">Ghana</h3>
          <p class="text-gray-200 dark:text-gray-300">Registered Operations</p>
        </div>
      </div>

      <a href="#contact" id="contact" class="mt-12 inline-block px-10 py-5 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition font-semibold text-lg">
        Invest with The Chocolate Future
      </a>
    </div>
  </section>

</Layout>

